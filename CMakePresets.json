{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 6
  },
  "configurePresets": [
    {
      "name": "linux-common",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_VERBOSE_MAKEFILE": "ON",
        "RUST_FEATURES": "ON",
        "BUILD_TESTING": "TRUE"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-clang",
      "hidden": true,
      "inherits": "linux-common",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "COMPILER_CACHE": ""
      }
    },
    {
      "name": "linux-gnu",
      "hidden": true,
      "inherits": "linux-common",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "COMPILER_CACHE": "ccache"
      }
    },
    {
      "name": "windows-clangcl",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_VERBOSE_MAKEFILE": "ON",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "RUST_FEATURES": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "COMPILER_CACHE": "sccache"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-msvc",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "cacheVariables": {
        "CMAKE_VERBOSE_MAKEFILE": "ON",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "RUST_FEATURES": "ON",
        "COMPILER_CACHE": "sccache"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "set"
      }
    },
    {
      "name": "windows-clang",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_VERBOSE_MAKEFILE": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "RUST_FEATURES": "OFF",
        "COMPILER_CACHE": ""
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-debug-clang",
      "displayName": "Linux Debug Clang",
      "description": "Linux Debug build with Clang",
      "inherits": "linux-clang",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-debug-clang-tsan",
      "displayName": "Linux Debug Clang TSan",
      "description": "Linux Debug with Thread Sanitizer",
      "inherits": "linux-clang",
      "binaryDir": "${sourceDir}/build_tsan/",
      "installDir": "${sourceDir}/build_tsan/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "myproject_ENABLE_SANITIZER_THREAD": "ON",
        "myproject_ENABLE_SANITIZER_ADDRESS": "OFF",
        "myproject_ENABLE_SANITIZER_UNDEFINED": "OFF"
      }
    },
    {
      "name": "linux-profile-clang",
      "displayName": "Linux Profile Clang",
      "description": "Linux RelWithDebInfo build with Clang (profiling)",
      "inherits": "linux-clang",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-RelWithDebInfo-clang",
      "displayName": "Linux RelWithDebInfo Clang",
      "description": "Linux RelWithDebInfo build with Clang",
      "inherits": "linux-clang",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "linux-release-clang",
      "displayName": "Linux Release Clang",
      "description": "Linux Release build with Clang",
      "inherits": "linux-clang",
      "binaryDir": "${sourceDir}/build-release/",
      "installDir": "${sourceDir}/build-release/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "linux-debug-GNU",
      "displayName": "Linux Debug GNU",
      "description": "Linux Debug build with GCC",
      "inherits": "linux-gnu",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-profile-GNU",
      "displayName": "Linux Profile GNU",
      "description": "Linux RelWithDebInfo build with GCC (profiling)",
      "inherits": "linux-gnu",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "linux-RelWithDebInfo-GNU",
      "displayName": "Linux RelWithDebInfo GNU",
      "description": "Linux RelWithDebInfo build with GCC",
      "inherits": "linux-gnu",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "linux-release-GNU",
      "displayName": "Linux Release GNU",
      "description": "Linux Release build with GCC",
      "inherits": "linux-gnu",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "x64-MSVC-Windows-Debug",
      "displayName": "Windows MSVC Debug",
      "description": "Windows Debug build with MSVC",
      "inherits": "windows-msvc",
      "binaryDir": "${sourceDir}/build-msvc-debug/",
      "installDir": "${sourceDir}/build-msvc-debug/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "TRUE"
      }
    },
    {
      "name": "x64-MSVC-Windows-Release",
      "displayName": "Windows MSVC Release",
      "description": "Windows Release build with MSVC",
      "inherits": "windows-msvc",
      "binaryDir": "${sourceDir}/build-msvc-release/",
      "installDir": "${sourceDir}/build-msvc-release/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "x64-ClangCL-Windows-Debug",
      "displayName": "Windows clang-cl Debug",
      "description": "Windows Debug build with clang-cl",
      "inherits": "windows-clangcl",
      "binaryDir": "${sourceDir}/build-clangcl-debug/",
      "installDir": "${sourceDir}/build-clangcl-debug/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "TRUE",
        "myproject_ENABLE_SANITIZER_ADDRESS": "ON"
      }
    },
    {
      "name": "x64-ClangCL-Windows-RelWithDebInfo",
      "displayName": "Windows clang-cl RelWithDebInfo",
      "description": "Windows RelWithDebInfo build with clang-cl",
      "inherits": "windows-clangcl",
      "binaryDir": "${sourceDir}/build-clangcl-relwithdebinfo/",
      "installDir": "${sourceDir}/build-clangcl-relwithdebinfo/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "x64-ClangCL-Windows-Profile",
      "displayName": "Windows clang-cl Profile",
      "description": "Windows Profile build with clang-cl",
      "inherits": "windows-clangcl",
      "binaryDir": "${sourceDir}/build-clangcl-profile/",
      "installDir": "${sourceDir}/build-clangcl-profile/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "TRUE"
      }
    },
    {
      "name": "x64-ClangCL-Windows-Release",
      "displayName": "Windows clang-cl Release",
      "description": "Windows Release build with clang-cl",
      "inherits": "windows-clangcl",
      "binaryDir": "${sourceDir}/build-clangcl-release/",
      "installDir": "${sourceDir}/build-clangcl-release/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "x64-Clang-Windows-Debug",
      "displayName": "Windows Clang Debug",
      "description": "Windows Debug build with Clang",
      "inherits": "windows-clang",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-Clang-Windows-RelWithDebInfo",
      "displayName": "Windows Clang RelWithDebInfo",
      "description": "Windows RelWithDebInfo build with Clang",
      "inherits": "windows-clang",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "x64-Clang-Windows-Release",
      "displayName": "Windows Clang Release",
      "description": "Windows Release build with Clang",
      "inherits": "windows-clang",
      "binaryDir": "${sourceDir}/build-release/",
      "installDir": "${sourceDir}/build-release/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "FALSE"
      }
    },
    {
      "name": "x64-Clang-Windows-Profile",
      "displayName": "Windows Clang Profile",
      "description": "Windows Profile build with Clang",
      "inherits": "windows-clang",
      "binaryDir": "${sourceDir}/build/",
      "installDir": "${sourceDir}/build/",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "jobs": 0,
      "configurePreset": "linux-debug-clang",
      "configuration": "Debug"
    },
    {
      "name": "linux-debug-clang",
      "jobs": 0,
      "configurePreset": "linux-debug-clang",
      "configuration": "Debug"
    },
    {
      "name": "linux-debug-clang-tsan",
      "jobs": 0,
      "configurePreset": "linux-debug-clang-tsan",
      "configuration": "Debug"
    },
    {
      "name": "linux-debug-GNU",
      "jobs": 0,
      "configurePreset": "linux-debug-GNU",
      "configuration": "Debug"
    },
    {
      "name": "linux-profile-GNU",
      "jobs": 0,
      "configurePreset": "linux-profile-GNU",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "linux-profile-clang",
      "jobs": 0,
      "configurePreset": "linux-profile-clang",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "linux-release-clang",
      "jobs": 0,
      "configurePreset": "linux-release-clang",
      "configuration": "Release"
    },
    {
      "name": "x64-MSVC-Windows-Debug",
      "jobs": 0,
      "configurePreset": "x64-MSVC-Windows-Debug",
      "configuration": "Debug"
    },
    {
      "name": "x64-MSVC-Windows-Release",
      "jobs": 0,
      "configurePreset": "x64-MSVC-Windows-Release",
      "configuration": "Release"
    },
    {
      "name": "x64-Clang-Windows-Debug",
      "jobs": 0,
      "configurePreset": "x64-Clang-Windows-Debug",
      "configuration": "Debug"
    },
    {
      "name": "x64-Clang-Windows-Release",
      "jobs": 0,
      "configurePreset": "x64-Clang-Windows-Release",
      "configuration": "Release"
    },
    {
      "name": "x64-ClangCL-Windows-Profile",
      "jobs": 0,
      "configurePreset": "x64-ClangCL-Windows-Profile",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "x64-ClangCL-Windows-RelWithDebInfo",
      "jobs": 0,
      "configurePreset": "x64-ClangCL-Windows-RelWithDebInfo",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "x64-ClangCL-Windows-Debug",
      "jobs": 0,
      "configurePreset": "x64-ClangCL-Windows-Debug",
      "configuration": "Debug"
    },
    {
      "name": "x64-ClangCL-Windows-Release",
      "jobs": 0,
      "configurePreset": "x64-ClangCL-Windows-Release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "linux-debug-clang",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": true
      }
    },
    {
      "name": "linux-debug-clang-tsan",
      "configurePreset": "linux-debug-clang-tsan",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": true
      }
    }
  ],
  "packagePresets": [
    {
      "name": "default",
      "configurePreset": "linux-debug-clang",
      "generators": [
        "TGZ"
      ]
    },
    {
      "name": "linux-debug-clang-tsan",
      "configurePreset": "linux-debug-clang-tsan",
      "generators": [
        "TGZ"
      ]
    },
    {
      "name": "linux-release-deb",
      "displayName": "Linux Release TGZ+DEB",
      "description": "Release TGZ and DEB package",
      "configurePreset": "linux-release-clang",
      "generators": [
        "TGZ",
        "DEB"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-clang-release-wix",
      "displayName": "Windows Release Clang NSIS+WIX",
      "description": "Windows installer packages via CPack",
      "configurePreset": "x64-Clang-Windows-Release",
      "generators": [
        "NSIS",
        "WIX",
        "ZIP"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "linux-debug-clang-workflow",
      "displayName": "Linux Debug Clang Workflow",
      "description": "Workflow preset for linux-debug-clang",
      "steps": [
        {
          "type": "configure",
          "name": "linux-debug-clang"
        },
        {
          "type": "build",
          "name": "default"
        },
        {
          "type": "test",
          "name": "default"
        },
        {
          "type": "package",
          "name": "default"
        }
      ]
    },
    {
      "name": "linux-debug-clang-tsan-workflow",
      "displayName": "Linux Debug Clang TSan Workflow",
      "description": "Workflow preset for linux-debug-clang-tsan",
      "steps": [
        {
          "type": "configure",
          "name": "linux-debug-clang-tsan"
        },
        {
          "type": "build",
          "name": "linux-debug-clang-tsan"
        },
        {
          "type": "test",
          "name": "linux-debug-clang-tsan"
        },
        {
          "type": "package",
          "name": "linux-debug-clang-tsan"
        }
      ]
    }
  ]
}